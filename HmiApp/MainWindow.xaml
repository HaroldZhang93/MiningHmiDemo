<Window x:Class="HmiApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HmiApp.ViewModels"
        xmlns:views="clr-namespace:HmiApp.Views"
        Title="综采工作面 Modbus 集中监控系统 (Phase 4)"
        WindowState="Maximized" WindowStartupLocation="CenterScreen"
        Width="1180" Height="680" MinWidth="900" MinHeight="540"
        FontFamily="Microsoft YaHei" FontSize="13"
        Background="{StaticResource Bg}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel Margin="8">
        <!-- 顶部：标题 + 连接 + KPI -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="综采工作面集中监控" Foreground="{StaticResource Cyan}"
                           FontSize="17" FontWeight="Bold" Margin="0,0,24,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="IP："/>
                    <TextBox Text="{Binding Ip}" Width="110"/>
                    <Button Content="{Binding ConnectText}" Command="{Binding ConnectCommand}" Width="120" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Cyan}" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- KPI -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <StackPanel Margin="14,0"><TextBlock Text="设备" Style="{StaticResource KpiCaption}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DeviceCount}" Foreground="{StaticResource TextLight}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/></StackPanel>
                    <StackPanel Margin="14,0"><TextBlock Text="运行" Style="{StaticResource KpiCaption}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RunningCount}" Foreground="{StaticResource Ok}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/></StackPanel>
                    <StackPanel Margin="14,0"><TextBlock Text="报警" Style="{StaticResource KpiCaption}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AlarmCount}" Foreground="{StaticResource Alarm}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/></StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主体：左侧 TabControl + 右侧常驻报文列（可拖动分隔） -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="350" MinWidth="280" MaxWidth="560"/>
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0">
                <TabItem Header="总览大屏"><views:OverviewView/></TabItem>
                <TabItem Header="设备控制"><views:DeviceControlView/></TabItem>
                <TabItem Header="综采三机"><views:ThreeMachineView/></TabItem>
                <TabItem Header="运输系统"><views:TransportView/></TabItem>
                <TabItem Header="供液 / 供电"><views:PowerFluidView/></TabItem>
                <TabItem Header="设备说明"><views:DeviceInfoView/></TabItem>
                <TabItem Header="PLC 控制"><views:PlcControlView DataContext="{Binding Plc}"/></TabItem>
                <TabItem Header="写入 / 调度"><views:WriteView/></TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#1A3358"/>

            <!-- 收发报文：常驻最右端 -->
            <views:FrameView Grid.Column="2" Margin="2,0,0,0"/>
        </Grid>
    </DockPanel>
</Window>
