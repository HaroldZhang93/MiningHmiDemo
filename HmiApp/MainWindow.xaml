<Window x:Class="HmiApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HmiApp"
        Title="综采设备 Modbus TCP 监控与控制上位机 (Phase 3)" Height="840" Width="1280"
        FontFamily="Microsoft YaHei" FontSize="13">
    <DockPanel Margin="8">

        <!-- ===== 顶部：连接栏 ===== -->
        <Border DockPanel.Dock="Top" Background="#0B1F3A" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="综采设备 Modbus 上位机" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Text="IP：" Foreground="#CCD" VerticalAlignment="Center"/>
                <TextBox x:Name="txtIp" Text="127.0.0.1" Width="120" VerticalAlignment="Center"/>
                <TextBlock Text="端口：" Foreground="#CCD" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox x:Name="txtPort" Text="1502" Width="60" VerticalAlignment="Center"/>
                <Button x:Name="btnConnect" Content="连接" Width="80" Margin="10,0,0,0" Click="OnConnectClick"/>
                <TextBlock x:Name="txtStatus" Text="未连接" Foreground="#FFD27F" VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== 主体：左(监测+趋势+写入) | 右(报文) ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 左列：监测 + 趋势 + 写入 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 实时监测表 -->
                <DataGrid x:Name="grid" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="All"
                          RowHeaderWidth="0" Margin="0,0,0,6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="设备"   Binding="{Binding Device}"      Width="90"/>
                        <DataGridTextColumn Header="点位"   Binding="{Binding Name}"        Width="150"/>
                        <DataGridTextColumn Header="数据区" Binding="{Binding AreaText}"    Width="150"/>
                        <DataGridTextColumn Header="地址"   Binding="{Binding AddressText}" Width="55"/>
                        <DataGridTextColumn Header="数值"   Binding="{Binding Value}"       Width="*"/>
                        <DataGridTextColumn Header="单位"   Binding="{Binding Unit}"        Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 趋势图 -->
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,6">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,4">
                            <TextBlock Text="趋势监测点：" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cboTrend" Width="220" DisplayMemberPath="Label"
                                      SelectionChanged="OnTrendPointChanged"/>
                        </StackPanel>
                        <local:TrendChart x:Name="trend"/>
                    </DockPanel>
                </Border>

                <!-- 写入 / 周期调度 -->
                <GroupBox Grid.Row="2" Header="写入 / 周期调度（题目二.3：地址 · 字节位 · 多字节 · 次数 · 周期）">
                    <StackPanel Margin="4">
                        <WrapPanel Margin="0,2">
                            <TextBlock Text="目标点位：" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cboWrite" Width="240" DisplayMemberPath="WriteLabel"/>
                            <TextBlock Text="值：" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="txtVal" Width="90" VerticalAlignment="Center" ToolTip="线圈填0/1；寄存器填整数；多寄存器用逗号分隔如 100,200,300"/>
                            <TextBlock Text="位(0-15)：" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="txtBit" Width="44" VerticalAlignment="Center" ToolTip="仅保持寄存器按位写时填；值填0/1"/>
                            <TextBlock Text="次数：" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="txtCount" Text="1" Width="50" VerticalAlignment="Center" ToolTip="0=无限"/>
                            <TextBlock Text="周期ms：" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="txtPeriod" Text="1000" Width="60" VerticalAlignment="Center"/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <Button x:Name="btnWriteOnce" Content="立即写一次" Width="100" Click="OnWriteOnce"/>
                            <Button x:Name="btnAddTask"   Content="加入周期任务" Width="110" Margin="8,0,0,0" Click="OnAddTask"/>
                            <Button x:Name="btnStopAll"   Content="停止全部任务" Width="110" Margin="8,0,0,0" Click="OnStopAll"/>
                            <TextBlock x:Name="txtWriteHint" Text="" Foreground="#C0392B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <DataGrid x:Name="dgTasks" Height="96" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="任务" Binding="{Binding Desc}" Width="*"/>
                                <DataGridTextColumn Header="周期ms" Binding="{Binding PeriodMs}" Width="70"/>
                                <DataGridTextColumn Header="剩余" Binding="{Binding RemainText}" Width="55"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120"/>
                                <DataGridTemplateColumn Header="操作" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="停止" Padding="6,0" Click="OnStopTask"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#EEE"/>

            <!-- 右列：报文查看器 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F4F6F8" Padding="6,4" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="收发报文" FontWeight="Bold" VerticalAlignment="Center"/>
                        <CheckBox x:Name="chkLogPoll" Content="记录轮询读报文" IsChecked="True" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <ToggleButton x:Name="btnPause" Content="暂停" Width="56" Margin="10,0,0,0"/>
                        <Button x:Name="btnClear" Content="清空" Width="56" Margin="8,0,0,0" Click="OnClearFrames"/>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="dgFrames" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0" FontFamily="Consolas" SelectionChanged="OnFrameSelected">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWrite}" Value="True">
                                    <Setter Property="Background" Value="#FFF8E1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding TimeText}" Width="90"/>
                        <DataGridTextColumn Header="方向" Binding="{Binding DirText}" Width="48"/>
                        <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" Margin="0,4,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="选中帧 · 逐字段解码" FontWeight="Bold" Background="#F4F6F8" Padding="6,3"/>
                        <TextBox x:Name="txtDetail" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Background="#1E1E1E" Foreground="#DDE" Padding="6"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
