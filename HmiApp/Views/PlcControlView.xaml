<UserControl x:Class="HmiApp.Views.PlcControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左：连接 + 状态 + 控制 -->
        <StackPanel Grid.Column="0">
            <Border Style="{StaticResource Card}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PLC 地址：" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding PlcIp}" Width="120"/>
                    <TextBlock Text="端口：" Margin="10,0,0,0"/>
                    <TextBox Text="{Binding PlcPort}" Width="56"/>
                    <Button Content="{Binding PlcConnectText}" Command="{Binding ConnectPlcCommand}" Width="90" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding PlcStatus}" Foreground="{StaticResource Cyan}" Margin="12,0,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="乳化泵设备状态（由 PLC 梯形图计算）" Style="{StaticResource H1}" Margin="0,0,0,10"/>
                    <UniformGrid Columns="2">
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <Ellipse Width="16" Height="16">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#555"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding PumpRunning}" Value="True"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="泵运行" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <Ellipse Width="16" Height="16">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#555"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding StartReq}" Value="True"><Setter Property="Fill" Value="{StaticResource Cyan}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="启泵请求(上位机下发)" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <Ellipse Width="16" Height="16">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#555"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding LowLevel}" Value="True"><Setter Property="Fill" Value="{StaticResource Alarm}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="低液位(PLC 联锁条件)" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <Ellipse Width="16" Height="16">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#555"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding EStop}" Value="True"><Setter Property="Fill" Value="{StaticResource Alarm}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="急停" Margin="8,0,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="控制（上位机 → PLC）" Style="{StaticResource H1}" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Content="启泵" Command="{Binding StartPumpCommand}" Width="80" Background="{StaticResource Ok}"/>
                        <Button Content="停泵" Command="{Binding StopPumpCommand}" Width="80"/>
                        <Button Content="急停" Command="{Binding TriggerEstopCommand}" Width="80" Background="{StaticResource Alarm}"/>
                        <Button Content="解除急停" Command="{Binding ClearEstopCommand}" Width="90"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="模拟液位(%)：" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding LevelValue}" Width="70"/>
                        <Button Content="写入液位" Command="{Binding SetLevelCommand}" Width="90" Margin="10,0,0,0"/>
                        <TextBlock Text="（写 &lt;20 触发低液位联锁）" Foreground="{StaticResource SubText}" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 右：说明 + 演示步骤 -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="这是什么 / 怎么演示" Style="{StaticResource H1}" Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextLight}" LineHeight="22">
                    <Run Text="本页连接的是真 PLC(OpenPLC) 而非模拟从站。乳化泵的实际启停由 PLC 梯形图按联锁逻辑决定，上位机只能下指令——这才是『控制 PLC』。"/>
                    <LineBreak/><LineBreak/>
                    <Run Text="PLC 梯形图逻辑：" FontWeight="Bold" Foreground="{StaticResource Cyan}"/>
                    <LineBreak/>
                    <Run Text="低液位 := 液位 &lt; 20；"/><LineBreak/>
                    <Run Text="泵运行 := 启泵请求 AND NOT 急停 AND NOT 低液位。"/>
                    <LineBreak/><LineBreak/>
                    <Run Text="演示步骤：" FontWeight="Bold" Foreground="{StaticResource Cyan}"/>
                    <LineBreak/>
                    <Run Text="1) 连接 PLC(127.0.0.1:502) → 点『启泵』→ 泵运行灯亮。"/><LineBreak/>
                    <Run Text="2) 写液位=10 → 低液位灯亮，泵运行灯灭：PLC 否决了上位机的启泵(安全联锁)。"/><LineBreak/>
                    <Run Text="3) 写液位=85 → 联锁解除，泵自动恢复运行。"/><LineBreak/>
                    <Run Text="4) 点『急停』→ 泵立即停；点『解除急停』→ 恢复。"/>
                    <LineBreak/><LineBreak/>
                    <Run Text="面试讲法：设备层(传感器/执行器) → 控制层(PLC 梯形图做联锁) → 应用层(上位机监控下发)，三层通过 Modbus TCP 打通，正是 JD 第5条『设备-控制-平台数据打通』。" Foreground="{StaticResource SubText}"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
