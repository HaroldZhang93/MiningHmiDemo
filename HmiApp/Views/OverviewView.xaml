<UserControl x:Class="HmiApp.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KPI 卡片行 -->
        <UniformGrid Grid.Row="0" Rows="1">
            <Border Style="{StaticResource Card}">
                <StackPanel><TextBlock Text="设备总数" Style="{StaticResource KpiCaption}"/>
                    <TextBlock Text="{Binding DeviceCount}" Style="{StaticResource KpiValue}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel><TextBlock Text="运行设备" Style="{StaticResource KpiCaption}"/>
                    <TextBlock Text="{Binding RunningCount}" Style="{StaticResource KpiValue}" Foreground="{StaticResource Ok}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel><TextBlock Text="当前报警" Style="{StaticResource KpiCaption}"/>
                    <TextBlock Text="{Binding AlarmCount}" Style="{StaticResource KpiValue}" Foreground="{StaticResource Alarm}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel><TextBlock Text="乳化泵出口压力" Style="{StaticResource KpiCaption}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding EmulPressure.Value}" Style="{StaticResource KpiValue}"/>
                        <TextBlock Text="{Binding EmulPressure.Unit}" Foreground="{StaticResource SubText}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel><TextBlock Text="采煤机截割电流" Style="{StaticResource KpiCaption}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ShearerCurrent.Value}" Style="{StaticResource KpiValue}"/>
                        <TextBlock Text="{Binding ShearerCurrent.Unit}" Foreground="{StaticResource SubText}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel><TextBlock Text="移变进线电压" Style="{StaticResource KpiCaption}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SubVoltage.Value}" Style="{StaticResource KpiValue}"/>
                        <TextBlock Text="{Binding SubVoltage.Unit}" Foreground="{StaticResource SubText}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel></StackPanel>
            </Border>
        </UniformGrid>

        <!-- 左趋势 / 右报警 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="实时趋势：" Style="{StaticResource H1}"/>
                        <ComboBox ItemsSource="{Binding AnalogPoints}" SelectedItem="{Binding TrendPoint}" Width="240">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock><Run Text="{Binding Device, Mode=OneWay}"/> · <Run Text="{Binding Name, Mode=OneWay}"/></TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <lvc:CartesianChart Series="{Binding TrendSeries}" XAxes="{Binding TrendXAxes}" YAxes="{Binding TrendYAxes}"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="实时报警" Style="{StaticResource H1}" Foreground="{StaticResource Alarm}" Margin="0,0,0,6"/>
                    <DataGrid ItemsSource="{Binding Alarms}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="设备" Binding="{Binding Device}" Width="*"/>
                            <DataGridTextColumn Header="报警点" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding Value}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
