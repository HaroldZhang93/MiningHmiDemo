<UserControl x:Class="HmiApp.Views.WriteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="写入 / 周期调度（题目二.3：地址 · 字节位 · 多字节 · 次数 · 周期）" Style="{StaticResource H1}" Margin="0,0,0,8"/>

            <StackPanel DockPanel.Dock="Top">
                <WrapPanel Margin="0,2">
                    <TextBlock Text="目标点位："/>
                    <ComboBox ItemsSource="{Binding WritablePoints}" SelectedItem="{Binding WriteTarget}" Width="250">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding WriteLabel}"/></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="值：" Margin="10,0,0,0"/>
                    <TextBox Text="{Binding WriteValue}" Width="90" ToolTip="线圈填0/1；寄存器填整数；多寄存器用逗号如 100,200,300"/>
                    <TextBlock Text="位(0-15)：" Margin="10,0,0,0"/>
                    <TextBox Text="{Binding WriteBit}" Width="44" ToolTip="保持寄存器按位写时填；值填0/1"/>
                    <TextBlock Text="次数：" Margin="10,0,0,0"/>
                    <TextBox Text="{Binding WriteCount}" Width="50" ToolTip="0=无限"/>
                    <TextBlock Text="周期ms：" Margin="10,0,0,0"/>
                    <TextBox Text="{Binding WritePeriod}" Width="60"/>
                </WrapPanel>
                <WrapPanel Margin="0,8">
                    <Button Content="立即写一次"   Command="{Binding WriteOnceCommand}" Width="100"/>
                    <Button Content="加入周期任务" Command="{Binding AddTaskCommand}" Width="110"/>
                    <Button Content="停止全部任务" Command="{Binding StopAllCommand}" Width="110"/>
                    <Button Content="一键写支架群压力设定 (FC16 连续8寄存器)" Command="{Binding WriteSupportGroupCommand}" Width="260" Background="{StaticResource Cyan}"/>
                </WrapPanel>
                <TextBlock Text="{Binding WriteHint}" Foreground="{StaticResource Warn}" Margin="0,0,0,8"/>
            </StackPanel>

            <GroupBox Header="周期写入任务">
                <DataGrid ItemsSource="{Binding Scheduler.Tasks}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务"   Binding="{Binding Desc}"      Width="*"/>
                        <DataGridTextColumn Header="周期ms" Binding="{Binding PeriodMs}"  Width="70"/>
                        <DataGridTextColumn Header="剩余"   Binding="{Binding RemainText}" Width="55"/>
                        <DataGridTextColumn Header="状态"   Binding="{Binding Status}"    Width="130"/>
                        <DataGridTemplateColumn Header="操作" Width="64">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="停止" Padding="6,0"
                                            Command="{Binding DataContext.StopTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </DockPanel>
    </Border>
</UserControl>
