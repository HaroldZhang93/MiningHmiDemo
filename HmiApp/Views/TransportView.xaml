<UserControl x:Class="HmiApp.Views.TransportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="运输系统：转载机 · 破碎机 · 皮带输送机" Style="{StaticResource H1}" Margin="0,0,0,6"/>
            <DataGrid ItemsSource="{Binding Transport}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                <Setter Property="Background" Value="#5A1F1F"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="设备"   Binding="{Binding Device}"      Width="120"/>
                    <DataGridTextColumn Header="点位"   Binding="{Binding Name}"        Width="160"/>
                    <DataGridTextColumn Header="数据区" Binding="{Binding AreaText}"    Width="110"/>
                    <DataGridTextColumn Header="地址"   Binding="{Binding AddressText}" Width="60"/>
                    <DataGridTextColumn Header="数值"   Binding="{Binding Value}"       Width="*"/>
                    <DataGridTextColumn Header="单位"   Binding="{Binding Unit}"        Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
